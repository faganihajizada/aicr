test_validate_agent_flags() {
  msg ""
  msg "=========================================="
  msg "Testing Validate Command Agent Flags"
  msg "=========================================="

  local help_output
  help_output=$("${EIDOS_BIN}" validate --help 2>&1)

  # Check all required agent flags exist
  local missing=""
  for flag in namespace node-selector toleration image job-name timeout cleanup privileged; do
    echo "$help_output" | grep -q "$flag" || missing="$missing $flag"
  done
  [ -z "$missing" ] && test_pass "validate-agent/flags-exist" || test_fail "validate-agent/flags-exist" "Missing:$missing"

  # Check help mentions agent/deploy
  echo "$help_output" | grep -qi "agent\|deploy" && \
    test_pass "validate-agent/help-mentions-agent" || \
    test_fail "validate-agent/help-mentions-agent" "Help should mention agent"
}

# ============================================================================
# EXTERNAL DATA DIRECTORY TESTS (--data flag)
# ============================================================================

test_external_data_flag() {
  msg ""
  msg "=========================================="
  msg "Testing External Data Directory"
  msg "=========================================="

  local dir=$(make_test_dir "external-data")

  # Test 1-2: Error cases
  run_cmd_fail "data/non-existent" "${EIDOS_BIN}" recipe --service eks --accelerator h100 --intent training --data "/non/existent" -o /dev/null
  mkdir -p "${dir}/empty"
  run_cmd_fail "data/missing-registry" "${EIDOS_BIN}" recipe --service eks --accelerator h100 --intent training --data "${dir}/empty" -o /dev/null

  # Test 3: Valid external data directory
  local valid="${dir}/valid"
  mkdir -p "$valid"
  cat > "${valid}/registry.yaml" << 'EOF'
apiVersion: eidos.nvidia.com/v1alpha1
kind: ComponentRegistry
components:
  - name: custom-operator
    displayName: Custom Operator
    helm:
      defaultRepository: https://test.example.com/charts
      defaultChart: custom/operator
      defaultVersion: v1.0.0
EOF
  run_cmd_ok "data/valid-dir" "${EIDOS_BIN}" recipe --service eks --accelerator h100 --intent training --data "$valid" -o "${dir}/recipe.yaml"
  check_file_exists "data/recipe-created" "${dir}/recipe.yaml"

  # Test 4: External data with custom overlay
  local overlay_dir="${dir}/with-overlay"
  mkdir -p "${overlay_dir}/overlays"
  echo 'apiVersion: eidos.nvidia.com/v1alpha1
kind: ComponentRegistry
components: []' > "${overlay_dir}/registry.yaml"
  cat > "${overlay_dir}/overlays/custom.yaml" << 'EOF'
apiVersion: eidos.nvidia.com/v1alpha1
kind: RecipeMetadata
metadata:
  name: custom-overlay
spec:
  criteria:
    service: eks
    accelerator: h100
    intent: training
  components:
    - name: cert-manager
      type: Helm
      source: https://charts.jetstack.io
      version: v1.16.3
EOF
  run_cmd_ok "data/custom-overlay" "${EIDOS_BIN}" recipe --service eks --accelerator h100 --intent training --data "$overlay_dir" -o "${dir}/overlay-recipe.yaml"

  # Test 5: Bundle with --data flag
  if [ -n "$RECIPE_FILE" ] && [ -f "$RECIPE_FILE" ]; then
    local bundle_dir="${dir}/bundle"
    mkdir -p "$bundle_dir"
    run_cmd_ok "data/bundle" "${EIDOS_BIN}" bundle -r "$RECIPE_FILE" -o "$bundle_dir" --data "$valid"
    verify_umbrella_chart "$bundle_dir" "data/bundle-structure"
  fi
}

# ============================================================================
# SNAPSHOT TEMPLATE FLAG TESTS
# ============================================================================

test_snapshot_template_flags() {
  msg ""
  msg "=========================================="
  msg "Testing Snapshot Template Flags"
  msg "=========================================="

  local dir=$(make_test_dir "snapshot-template")
  local template="${dir}/test.tmpl"
  cat > "$template" << 'EOF'
kind: {{ .Kind }}
apiVersion: {{ .APIVersion }}
EOF

  # Test 1: Template flag exists in help
  local help=$("${EIDOS_BIN}" snapshot --help 2>&1)
  echo "$help" | grep -q "template" && test_pass "template/flag-exists" || test_fail "template/flag-exists" "Not found"

  # Test 2-3: Format validation with template
  "${EIDOS_BIN}" snapshot --template "$template" --format yaml 2>&1 | grep -qi "error.*format" && \
    test_fail "template/yaml-format" "Should be valid" || test_pass "template/yaml-format"

  run_cmd_grep "template/json-rejected" "YAML format\|requires YAML" \
    "${EIDOS_BIN}" snapshot --template "$template" --format json

  # Test 4-5: Invalid template paths
  run_cmd_grep "template/nonexistent" "not found\|no such file\|does not exist" \
    "${EIDOS_BIN}" snapshot --template "/non/existent.tmpl"
  run_cmd_grep "template/directory" "directory\|not a file" \
    "${EIDOS_BIN}" snapshot --template "$dir"

  # Test 6: Example template exists
  check_file_exists "template/example-exists" "${ROOT}/examples/templates/snapshot-template.md.tmpl"

  # Test 7: Standard formats without template
  for fmt in yaml json; do
    "${EIDOS_BIN}" snapshot --format "$fmt" 2>&1 | grep -qi "invalid format\|unknown format" && \
      test_fail "template/no-template-${fmt}" "Should be valid" || test_pass "template/no-template-${fmt}"
  done
}

# ============================================================================
# CUJ1: Critical User Journey - Training Workload
# ============================================================================
# Tests the complete workflow from docs/demos/cuj1.md:
#   recipe (with platform) → validate → bundle → helm validation
# ============================================================================

test_cuj1() {
  msg ""
  msg "=========================================="
  msg "CUJ1: Training Workload Journey"
  msg "=========================================="

  local dir=$(make_test_dir "cuj1")

  # Step 1: Generate recipe with kubeflow platform (per CUJ1 doc)
  msg "--- Step 1: Recipe with --platform kubeflow ---"
  local recipe="${dir}/recipe.yaml"
  run_cmd_ok "cuj1/recipe" "${EIDOS_BIN}" recipe \
    --service eks \
    --accelerator h100 \
    --intent training \
    --os ubuntu \
    --platform kubeflow \
    --output "$recipe"

  check_file_exists "cuj1/recipe-created" "$recipe"
  check_file_contains "cuj1/recipe-has-kubeflow" "$recipe" "kubeflow"

  # Step 2: Validate recipe (readiness phase with agent flags)
  msg "--- Step 2: Validate with agent flags ---"
  local snapshot="${dir}/snapshot.yaml"
  cat > "$snapshot" << 'EOF'
measurements:
  - type: K8s
    subtypes:
      - name: server
        data:
          version: v1.33.0
  - type: OS
    subtypes:
      - name: release
        data:
          ID: ubuntu
          VERSION_ID: "24.04"
EOF

  # Test validate with --namespace and --node-selector flags (CUJ1 specific)
  local validate_output
  validate_output=$("${EIDOS_BIN}" validate \
    --recipe "$recipe" \
    --snapshot "$snapshot" \
    --phase readiness 2>&1) || true
  echo "$validate_output" | grep -qi "readiness\|validation" && \
    test_pass "cuj1/validate-readiness" || \
    test_fail "cuj1/validate-readiness" "Validation output unexpected"

  # Step 3: Generate bundle with selectors/tolerations (per CUJ1 doc)
  msg "--- Step 3: Bundle with node scheduling ---"
  local bundle="${dir}/bundle"
  mkdir -p "$bundle"
  run_cmd_ok "cuj1/bundle" "${EIDOS_BIN}" bundle \
    --recipe "$recipe" \
    --output "$bundle" \
    --system-node-selector nodeGroup=system-pool \
    --accelerated-node-selector nodeGroup=gpu-worker \
    --accelerated-node-toleration nvidia.com/gpu=present:NoSchedule

  verify_umbrella_chart "$bundle" "cuj1/bundle-structure"
  check_file_contains "cuj1/bundle-sys-selector" "${bundle}/values.yaml" "system-pool"
  check_file_contains "cuj1/bundle-accel-selector" "${bundle}/values.yaml" "gpu-worker"
  check_file_contains "cuj1/bundle-toleration" "${bundle}/values.yaml" "nvidia.com/gpu"

  # Step 4: Helm validation (simulates install prep)
  msg "--- Step 4: Helm chart validation ---"
  verify_helm_chart "$bundle" "cuj1"

  # Step 5: Multi-phase validate (CUJ1 final validation)
  msg "--- Step 5: Multi-phase validation ---"
  validate_output=$("${EIDOS_BIN}" validate \
    --recipe "$recipe" \
    --snapshot "$snapshot" \
    --phase readiness \
    --phase deployment \
    --phase conformance 2>&1) || true
  if echo "$validate_output" | grep -q "readiness" && \
     echo "$validate_output" | grep -q "deployment" && \
     echo "$validate_output" | grep -q "conformance"; then
    test_pass "cuj1/multi-phase-validate"
  else
    test_fail "cuj1/multi-phase-validate" "Expected all three phases"
  fi

  msg "CUJ1 tests completed"
}

