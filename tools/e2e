#!/bin/bash
set -euo pipefail

# =============================================================================
# E2E Integration Tests for eidos CLI
# =============================================================================
#
# PURPOSE:
# This script tests the compiled eidos binary and CLI flag handling.
# It complements Go unit tests by testing what can only be verified after
# the binary is built: CLI argument parsing, flag combinations, and
# end-to-end command execution.
#
# WHAT THIS SCRIPT TESTS:
# - Binary builds successfully (make build)
# - Critical User Journeys (CUJ1: recipe → validate → bundle → install)
# - CLI workflow: eidos recipe → eidos bundle
# - CLI flags: --set, --system-node-selector, --accelerated-node-toleration, etc.
# - Flag combinations and interactions
# - Helm chart validation (if helm is available)
#
# WHAT GO TESTS COVER (not duplicated here):
# - YAML file validation: pkg/recipe/yaml_test.go
# - Metadata behavior: pkg/recipe/metadata_test.go
# - Recipe validation: pkg/recipe/recipe_test.go
#
# =============================================================================

# Dir setup
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${DIR}/common"
ROOT=$(dirname "${DIR}")

# Check required tools
has_tools awk find grep make sed uname

# Check optional tools (helm for chart validation)
HELM_AVAILABLE=false
if command -v helm &> /dev/null; then
  HELM_AVAILABLE=true
  msg "Helm found: $(helm version --short 2>/dev/null || echo 'unknown version')"
else
  msg "Warning: helm not found, skipping Helm chart validation tests"
fi

# Default values
OUTPUT_DIR=""
EIDOS_BIN=""

# Test configuration
TOTAL_TESTS=0
PASSED_TESTS=0
FAILED_TESTS=0

# Parse flags
usage() {
  cat << EOF
Usage: $0 [OPTIONS]

Options:
  -o, --output PATH     Output directory for test artifacts (default: temp dir)
  -h, --help            Show this help message

E2E Integration Tests for eidos CLI - tests compiled binary behavior.

Examples:
  $0                        # Run all tests with temp output
  $0 -o ./test-output       # Run tests with custom output directory
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case $1 in
    -o|--output)
      OUTPUT_DIR="$2"
      shift 2
      ;;
    -h|--help)
      usage
      ;;
    *)
      err "Unknown option: $1"
      ;;
  esac
done

# Set output directory
if [ -z "$OUTPUT_DIR" ]; then
  OUTPUT_DIR=$(mktemp -d)
  msg "Using temp directory: ${OUTPUT_DIR}"
fi
mkdir -p "${OUTPUT_DIR}"

# ============================================================================
# TEST HELPERS
# ============================================================================

test_pass() {
  local name=$1
  TOTAL_TESTS=$((TOTAL_TESTS + 1))
  PASSED_TESTS=$((PASSED_TESTS + 1))
  printf "${COLOR_GREEN}[PASS]${COLOR_RESET} %s\n" "$name"
}

test_fail() {
  local name=$1
  local reason=$2
  TOTAL_TESTS=$((TOTAL_TESTS + 1))
  FAILED_TESTS=$((FAILED_TESTS + 1))
  printf "${COLOR_RED}[FAIL]${COLOR_RESET} %s: %s\n" "$name" "$reason"
}

# Create a test directory and echo its path
# Usage: local dir=$(make_test_dir "subdir-name")
make_test_dir() {
  local name=$1
  local dir="${OUTPUT_DIR}/${name}"
  mkdir -p "$dir"
  echo "$dir"
}

# Run a command and check if it succeeds
# Usage: run_cmd_ok "test-name" command args...
run_cmd_ok() {
  local name=$1
  shift
  if "$@" >/dev/null 2>&1; then
    test_pass "$name"
    return 0
  else
    test_fail "$name" "Command failed: $*"
    return 1
  fi
}

# Run a command and check if it fails (for negative tests)
# Usage: run_cmd_fail "test-name" command args...
run_cmd_fail() {
  local name=$1
  shift
  if "$@" >/dev/null 2>&1; then
    test_fail "$name" "Command should have failed"
    return 1
  else
    test_pass "$name"
    return 0
  fi
}

# Run a command and check output contains a pattern
# Usage: run_cmd_grep "test-name" "pattern" command args...
run_cmd_grep() {
  local name=$1
  local pattern=$2
  shift 2
  local output
  output=$("$@" 2>&1) || true
  if echo "$output" | grep -qi "$pattern"; then
    test_pass "$name"
    return 0
  else
    test_fail "$name" "Pattern '$pattern' not found in output"
    return 1
  fi
}

# Check if a file exists
# Usage: check_file_exists "test-name" "/path/to/file"
check_file_exists() {
  local name=$1
  local file=$2
  if [ -f "$file" ]; then
    test_pass "$name"
    return 0
  else
    test_fail "$name" "File not found: $file"
    return 1
  fi
}

# Check if a pattern exists in a file
# Usage: check_file_contains "test-name" "/path/to/file" "pattern"
check_file_contains() {
  local name=$1
  local file=$2
  local pattern=$3
  if [ ! -f "$file" ]; then
    test_fail "$name" "File not found: $file"
    return 1
  fi
  if grep -q "$pattern" "$file"; then
    test_pass "$name"
    return 0
  else
    test_fail "$name" "Pattern '$pattern' not in $file"
    return 1
  fi
}

# ============================================================================
# BUNDLE VERIFICATION HELPERS
# ============================================================================

# Verify umbrella chart structure
verify_umbrella_chart() {
  local bundle_dir=$1
  local test_name=$2
  local required_files=("Chart.yaml" "values.yaml" "README.md" "recipe.yaml")

  for file in "${required_files[@]}"; do
    if [ ! -f "${bundle_dir}/${file}" ]; then
      test_fail "$test_name" "Missing: ${file}"
      return 1
    fi
  done

  if ! grep -q "dependencies:" "${bundle_dir}/Chart.yaml"; then
    test_fail "$test_name" "Chart.yaml missing dependencies"
    return 1
  fi

  if [ ! -s "${bundle_dir}/values.yaml" ]; then
    test_fail "$test_name" "values.yaml is empty"
    return 1
  fi

  test_pass "$test_name"
}

# Verify Helm chart validity (lint, deps, template)
verify_helm_chart() {
  local bundle_dir=$1
  local test_name=$2

  [ "$HELM_AVAILABLE" != "true" ] && return 0

  # Fix "dev" version for helm
  local chart_file="${bundle_dir}/Chart.yaml"
  if grep -q "version: dev" "$chart_file" 2>/dev/null; then
    sed -i.bak 's/version: dev/version: 0.0.0-dev/' "$chart_file"
    rm -f "${chart_file}.bak"
  fi

  # Helm lint
  local lint_output
  if ! lint_output=$(helm lint "$bundle_dir" 2>&1); then
    if echo "$lint_output" | grep -q "chart directory is missing these dependencies"; then
      # Expected - dependencies aren't downloaded
      if echo "$lint_output" | grep -q "Error:"; then
        test_fail "${test_name}/helm-lint" "$(echo "$lint_output" | grep "Error:")"
        return 1
      fi
    else
      test_fail "${test_name}/helm-lint" "$lint_output"
      return 1
    fi
  fi
  test_pass "${test_name}/helm-lint"

  # Helm dependency update (optional - may fail without network)
  if timeout 60 helm dependency update "$bundle_dir" >/dev/null 2>&1; then
    test_pass "${test_name}/helm-dep-update"
    # Skip helm template - it can be very slow with large umbrella charts
    # and may fail due to missing namespace/values requirements
  fi
}

# Verify ArgoCD App of Apps structure
verify_argocd_structure() {
  local bundle_dir=$1
  local test_name=$2

  check_file_exists "${test_name}/app-of-apps" "${bundle_dir}/app-of-apps.yaml" || return 1
  check_file_contains "${test_name}/kind" "${bundle_dir}/app-of-apps.yaml" "kind: Application" || return 1

  # Find at least one component with application.yaml and sync-wave
  for dir in "${bundle_dir}"/*/; do
    if [ -d "$dir" ] && [ -f "${dir}application.yaml" ]; then
      check_file_exists "${test_name}/component-values" "${dir}values.yaml" || return 1
      check_file_contains "${test_name}/sync-wave" "${dir}application.yaml" "argocd.argoproj.io/sync-wave" || return 1
      test_pass "$test_name"
      return 0
    fi
  done

  test_fail "$test_name" "No component directories found"
  return 1
}

# ============================================================================
# BUILD
# ============================================================================

build_binary() {
  msg "=========================================="
  msg "Building eidos binary"
  msg "=========================================="
  
  cd "${ROOT}"
  
  if ! make build 2>&1; then
    err "Failed to build eidos binary"
  fi
  
  # Find the built binary (platform-specific)
  local os_name=$(uname -s | tr '[:upper:]' '[:lower:]')
  local arch_name=$(uname -m)
  
  # Convert arch name
  case "$arch_name" in
    x86_64) arch_name="amd64" ;;
    aarch64|arm64) arch_name="arm64" ;;
  esac
  
  # Try to find the binary with various naming patterns
  # goreleaser uses different suffixes:
  # - _v1 for amd64 (x86_64 microarchitecture level 1)
  # - _v8.0 for arm64 (ARMv8.0 baseline)
  EIDOS_BIN=""
  for pattern in \
    "${ROOT}/dist/eidos_${os_name}_${arch_name}/eidos" \
    "${ROOT}/dist/eidos_${os_name}_${arch_name}_v1/eidos" \
    "${ROOT}/dist/eidos_${os_name}_${arch_name}_v8.0/eidos" \
    "${ROOT}/dist/eidos_${os_name}_all/eidos"; do
    if [ -x "$pattern" ]; then
      EIDOS_BIN="$pattern"
      break
    fi
  done
  
  if [ -z "$EIDOS_BIN" ] || [ ! -x "$EIDOS_BIN" ]; then
    err "Built binary not found in dist/"
  fi
  
  test_pass "build/eidos-binary"
  msg "Using binary: ${EIDOS_BIN}"
}

# ============================================================================
# RECIPE DATA FILE TESTS
# ============================================================================

# Test that leaf recipe data files can be used to generate recipes and bundles via CLI.
# This is a smoke test to verify the CLI workflow works end-to-end.
#
# Note: Detailed validation of YAML files (parsing, references, enums, constraints,
# inheritance chains) is covered by Go tests in pkg/recipe/yaml_test.go and
# pkg/recipe/metadata_test.go. This test only verifies CLI integration.
test_all_recipe_data_files() {
  msg ""
  msg "=========================================="
  msg "Testing CLI Workflow for Leaf Recipes"
  msg "=========================================="
  
  local recipe_data_dir="${ROOT}/pkg/recipe/data/overlays"
  local all_recipes_dir="${OUTPUT_DIR}/bundles/all-recipes"
  mkdir -p "$all_recipes_dir"
  
  # Find all overlay recipe files (exclude base.yaml)
  local recipe_files
  recipe_files=$(find "$recipe_data_dir" -maxdepth 1 -name "*.yaml" ! -name "base.yaml" -type f | sort)
  
  if [ -z "$recipe_files" ]; then
    test_fail "cli-workflow/find-files" "No recipe files found in ${recipe_data_dir}"
    return 1
  fi
  
  local leaf_count=0
  local skip_count=0
  
  for recipe_file in $recipe_files; do
    local basename
    basename=$(basename "$recipe_file" .yaml)
    
    # Extract criteria from the recipe metadata file
    local service accelerator os_val intent platform
    service=$(awk '/^  criteria:/{in_crit=1;next} in_crit && /^  [a-z]/{exit} in_crit && /service:/{gsub(/.*service: /,""); print}' "$recipe_file")
    accelerator=$(awk '/^  criteria:/{in_crit=1;next} in_crit && /^  [a-z]/{exit} in_crit && /accelerator:/{gsub(/.*accelerator: /,""); print}' "$recipe_file")
    os_val=$(awk '/^  criteria:/{in_crit=1;next} in_crit && /^  [a-z]/{exit} in_crit && /os:/{gsub(/.*os: /,""); print}' "$recipe_file")
    intent=$(awk '/^  criteria:/{in_crit=1;next} in_crit && /^  [a-z]/{exit} in_crit && /intent:/{gsub(/.*intent: /,""); print}' "$recipe_file")
    platform=$(awk '/^  criteria:/{in_crit=1;next} in_crit && /^  [a-z]/{exit} in_crit && /platform:/{gsub(/.*platform: /,""); print}' "$recipe_file")
    
    # Skip intermediate recipes (those without complete criteria)
    # Go tests validate intermediate recipes; here we only test CLI with leaf recipes
    if [ -z "$accelerator" ] || [ -z "$os_val" ] || [ -z "$intent" ]; then
      skip_count=$((skip_count + 1))
      continue
    fi
    
    leaf_count=$((leaf_count + 1))
    local test_dir="${all_recipes_dir}/${basename}"
    mkdir -p "$test_dir"
    
    # Build CLI command
    local recipe_result="${test_dir}/recipe.yaml"
    local recipe_cmd="${EIDOS_BIN} recipe --accelerator $accelerator --os $os_val --intent $intent"
    if [ -n "$service" ]; then
      recipe_cmd="$recipe_cmd --service $service"
    fi
    if [ -n "$platform" ]; then
      recipe_cmd="$recipe_cmd --platform $platform"
    fi
    recipe_cmd="$recipe_cmd -o $recipe_result"
    
    # Test: CLI generates recipe
    if ! eval "$recipe_cmd" 2>&1; then
      test_fail "cli-workflow/${basename}/recipe" "Failed to generate recipe"
      continue
    fi
    
    # Test: CLI generates bundle
    local bundle_dir="${test_dir}/bundles"
    if ! "${EIDOS_BIN}" bundle -r "$recipe_result" -o "$bundle_dir" 2>&1; then
      test_fail "cli-workflow/${basename}/bundle" "Failed to generate bundle"
      continue
    fi
    
    # Test: Verify umbrella chart structure
    if ! verify_umbrella_chart "$bundle_dir" "cli-workflow/${basename}/umbrella-chart"; then
      continue
    fi

    # Test: Verify Helm chart validity
    verify_helm_chart "$bundle_dir" "cli-workflow/${basename}"

    # Count dependencies in Chart.yaml (indicates number of components)
    local dep_count
    dep_count=$(grep -c "^  - name:" "${bundle_dir}/Chart.yaml" 2>/dev/null || echo "0")

    test_pass "cli-workflow/${basename} (${dep_count} dependencies)"
  done
  
  msg ""
  msg "Tested ${leaf_count} leaf recipes (skipped ${skip_count} intermediate recipes)"
}

# ============================================================================
# RECIPE GENERATION (Query Mode)
# ============================================================================

RECIPE_FILE=""

generate_recipe() {
  msg ""
  msg "=========================================="
  msg "Generating Recipe (Query Mode)"
  msg "=========================================="
  msg "Parameters: service=eks, accelerator=gb200, os=ubuntu, intent=training"
  
  RECIPE_FILE="${OUTPUT_DIR}/recipe.yaml"
  
  if ! "${EIDOS_BIN}" recipe \
    --service eks \
    --accelerator gb200 \
    --os ubuntu \
    --intent training \
    --output "${RECIPE_FILE}" 2>&1; then
    test_fail "recipe/generation" "Failed to generate recipe"
    return 1
  fi
  
  # Verify recipe file was created
  if [ ! -f "$RECIPE_FILE" ]; then
    test_fail "recipe/file-exists" "Recipe file was not created"
    return 1
  fi
  test_pass "recipe/file-exists"
  
  # Verify recipe contains expected kind (note: kind is lowercase in output)
  if ! grep -q "kind: recipeResult" "$RECIPE_FILE"; then
    test_fail "recipe/valid-format" "Recipe does not contain 'kind: recipeResult'"
    return 1
  fi
  test_pass "recipe/valid-format"
  
  # Verify recipe contains gpu-operator component
  if ! grep -q "gpu-operator" "$RECIPE_FILE"; then
    test_fail "recipe/has-gpu-operator" "Recipe does not contain gpu-operator component"
    return 1
  fi
  test_pass "recipe/has-gpu-operator"
  
  # Verify recipe contains skyhook-operator component
  if ! grep -q "skyhook-operator" "$RECIPE_FILE"; then
    test_fail "recipe/has-skyhook-operator" "Recipe does not contain skyhook-operator component"
    return 1
  fi
  test_pass "recipe/has-skyhook-operator"
  
  msg "Recipe saved to: ${RECIPE_FILE}"
}

# ============================================================================
# BUNDLE TESTS (Table-Driven)
# ============================================================================

# Run a single bundle test case
# Args: name, flags (space-separated), patterns_to_check (pipe-separated)
run_bundle_test() {
  local name=$1
  local flags=$2
  local patterns=$3

  local dir=$(make_test_dir "bundles/${name}")

  # Build command
  local cmd="${EIDOS_BIN} bundle -r ${RECIPE_FILE} -o ${dir} ${flags}"

  if ! eval "$cmd" >/dev/null 2>&1; then
    test_fail "bundle/${name}/generation" "Bundle generation failed"
    return 1
  fi
  test_pass "bundle/${name}/generation"

  # Verify umbrella chart structure
  verify_umbrella_chart "$dir" "bundle/${name}/structure" || return 1

  # Check patterns in values.yaml (pipe-separated list)
  if [ -n "$patterns" ]; then
    IFS='|' read -ra pattern_array <<< "$patterns"
    for pattern in "${pattern_array[@]}"; do
      local pattern_name=$(echo "$pattern" | tr '.' '-' | tr '/' '-')
      check_file_contains "bundle/${name}/${pattern_name}" "${dir}/values.yaml" "$pattern" || true
    done
  fi

  # Helm validation
  verify_helm_chart "$dir" "bundle/${name}"
}

run_bundle_tests() {
  msg ""
  msg "=========================================="
  msg "Running Bundle Generation Tests"
  msg "=========================================="

  # Test 1: Basic bundle (no flags)
  run_bundle_test "basic" "" "gpu-operator"

  # Test 2: System node selector
  run_bundle_test "sys-selector" \
    "--system-node-selector nodeGroup=system-pool" \
    "nodeGroup|system-pool"

  # Test 3: Accelerated node selector
  run_bundle_test "accel-selector" \
    "--accelerated-node-selector accelerator=nvidia-gpu" \
    "accelerator|nvidia-gpu"

  # Test 4: System node toleration
  run_bundle_test "sys-toleration" \
    "--system-node-toleration dedicated=system-workload:NoSchedule" \
    "dedicated|system-workload"

  # Test 5: Accelerated node toleration
  run_bundle_test "accel-toleration" \
    "--accelerated-node-toleration nvidia.com/gpu=present:NoSchedule" \
    "nvidia.com/gpu"

  # Test 6: Value override (--set)
  run_bundle_test "value-override" \
    "--set gpu-operator:driver.version=999.99.99" \
    "999.99.99"

  # Test 7: Combined (all flags)
  run_bundle_test "combined" \
    "--system-node-selector nodeGroup=system-pool --system-node-toleration dedicated=system:NoSchedule --accelerated-node-selector accelerator=nvidia-gpu --accelerated-node-toleration nvidia.com/gpu=present:NoSchedule --set gpu-operator:driver.version=888.88.88" \
    "nodeGroup|dedicated|accelerator|nvidia.com/gpu|888.88.88"

  # Test 8: ArgoCD deployer (special case)
  msg ""
  msg "--- ArgoCD Deployer ---"
  local argocd_dir=$(make_test_dir "bundles/argocd")
  if "${EIDOS_BIN}" bundle -r "$RECIPE_FILE" -o "$argocd_dir" --deployer argocd >/dev/null 2>&1; then
    test_pass "bundle/argocd/generation"
    verify_argocd_structure "$argocd_dir" "bundle/argocd"
  else
    test_fail "bundle/argocd/generation" "ArgoCD bundle failed"
  fi
}

# ============================================================================
# CRITERIA FILE TESTS (--criteria flag)
# ============================================================================

test_criteria_file_flag() {
  msg ""
  msg "=========================================="
  msg "Testing Criteria File Support"
  msg "=========================================="

  local dir=$(make_test_dir "criteria-file")

  # Create valid YAML criteria file
  local yaml_criteria="${dir}/criteria.yaml"
  cat > "$yaml_criteria" << 'EOF'
kind: recipeCriteria
apiVersion: eidos.nvidia.com/v1alpha1
metadata:
  name: test-criteria
spec:
  service: eks
  accelerator: h100
  os: ubuntu
  intent: training
EOF

  # Test 1: Valid YAML criteria
  local yaml_recipe="${dir}/yaml-recipe.yaml"
  run_cmd_ok "criteria/yaml" "${EIDOS_BIN}" recipe --criteria "$yaml_criteria" -o "$yaml_recipe"
  check_file_exists "criteria/yaml-created" "$yaml_recipe"

  # Test 2: Valid JSON criteria
  local json_criteria="${dir}/criteria.json"
  cat > "$json_criteria" << 'EOF'
{"kind":"recipeCriteria","apiVersion":"eidos.nvidia.com/v1alpha1","metadata":{"name":"test"},"spec":{"service":"gke","accelerator":"a100","os":"ubuntu","intent":"inference"}}
EOF
  run_cmd_ok "criteria/json" "${EIDOS_BIN}" recipe --criteria "$json_criteria" -o "${dir}/json-recipe.yaml"

  # Test 3: CLI flag overrides criteria file
  local override_recipe="${dir}/override.yaml"
  run_cmd_ok "criteria/override" "${EIDOS_BIN}" recipe --criteria "$yaml_criteria" --service gke -o "$override_recipe"
  check_file_contains "criteria/override-applied" "$override_recipe" "gke"

  # Test 4-6: Invalid criteria files (should fail)
  echo 'kind: wrongKind' > "${dir}/invalid-kind.yaml"
  run_cmd_fail "criteria/invalid-kind" "${EIDOS_BIN}" recipe --criteria "${dir}/invalid-kind.yaml" -o /dev/null

  echo 'kind: recipeCriteria
apiVersion: wrong.version/v1' > "${dir}/invalid-version.yaml"
  run_cmd_fail "criteria/invalid-apiversion" "${EIDOS_BIN}" recipe --criteria "${dir}/invalid-version.yaml" -o /dev/null

  echo 'kind: recipeCriteria
apiVersion: eidos.nvidia.com/v1alpha1
spec:
  service: invalid-service' > "${dir}/invalid-enum.yaml"
  run_cmd_fail "criteria/invalid-enum" "${EIDOS_BIN}" recipe --criteria "${dir}/invalid-enum.yaml" -o /dev/null

  # Test 7: Non-existent file
  run_cmd_fail "criteria/non-existent" "${EIDOS_BIN}" recipe --criteria "/non/existent/file.yaml" -o /dev/null

  # Test 8: Criteria file with bundle
  local bundle_dir="${dir}/bundle"
  mkdir -p "$bundle_dir"
  run_cmd_ok "criteria/bundle" "${EIDOS_BIN}" bundle -r "$yaml_recipe" -o "$bundle_dir"
  verify_umbrella_chart "$bundle_dir" "criteria/bundle-structure"

  # Test 9: Partial criteria (only accelerator)
  echo 'kind: recipeCriteria
apiVersion: eidos.nvidia.com/v1alpha1
spec:
  accelerator: h100' > "${dir}/partial.yaml"
  run_cmd_ok "criteria/partial" "${EIDOS_BIN}" recipe --criteria "${dir}/partial.yaml" -o "${dir}/partial-recipe.yaml"
}

# ============================================================================
# VALIDATION MULTI-PHASE TESTS (--phase flag)
# ============================================================================

test_validate_phases() {
  msg ""
  msg "=========================================="
  msg "Testing Multi-Phase Validation"
  msg "=========================================="

  local dir=$(make_test_dir "validate-phases")

  # Generate recipe if needed
  local recipe_file="${RECIPE_FILE:-}"
  if [ -z "$recipe_file" ] || [ ! -f "$recipe_file" ]; then
    recipe_file="${dir}/test-recipe.yaml"
    "${EIDOS_BIN}" recipe --service eks --accelerator h100 --intent training \
      -o "$recipe_file" >/dev/null 2>&1 || {
      test_fail "validate/setup" "Failed to generate recipe"
      return 0
    }
  fi

  # Create mock snapshot
  local snapshot="${dir}/snapshot.yaml"
  cat > "$snapshot" << 'EOF'
measurements:
  - type: K8s
    subtypes:
      - name: server
        data:
          version: v1.33.0
  - type: OS
    subtypes:
      - name: release
        data:
          ID: ubuntu
          VERSION_ID: "24.04"
EOF

  # Test individual phases
  for phase in readiness deployment performance conformance; do
    run_cmd_grep "validate/phase-${phase}" "$phase" \
      "${EIDOS_BIN}" validate -r "$recipe_file" -s "$snapshot" --phase "$phase"
  done

  # Test --phase all
  local all_output="${dir}/all-phases.yaml"
  local output
  output=$("${EIDOS_BIN}" validate -r "$recipe_file" -s "$snapshot" --phase all -o "$all_output" 2>&1) || true
  local count=0
  echo "$output" | grep -q "readiness" && ((count++)) || true
  echo "$output" | grep -q "deployment" && ((count++)) || true
  echo "$output" | grep -q "performance" && ((count++)) || true
  [ $count -ge 3 ] && test_pass "validate/phase-all" || test_fail "validate/phase-all" "Expected 3+ phases"

  # Test result structure
  [ -f "$all_output" ] && check_file_contains "validate/result-structure" "$all_output" "phases:"

  # Test invalid phase
  run_cmd_grep "validate/invalid-phase" "invalid phase" \
    "${EIDOS_BIN}" validate -r "$recipe_file" -s "$snapshot" --phase invalid-phase

  # Test multiple --phase flags
  output=$("${EIDOS_BIN}" validate -r "$recipe_file" -s "$snapshot" \
    --phase readiness --phase deployment --phase conformance 2>&1) || true
  if echo "$output" | grep -q "readiness" && \
     echo "$output" | grep -q "deployment" && \
     echo "$output" | grep -q "conformance"; then
    test_pass "validate/multi-phase"
  else
    test_fail "validate/multi-phase" "Expected all three phases"
  fi
}

# ============================================================================
# DUPLICATE FLAG VALIDATION TESTS
# ============================================================================

test_duplicate_flag_validation() {
  msg ""
  msg "=========================================="
  msg "Testing Duplicate Flag Validation"
  msg "=========================================="

  local dir=$(make_test_dir "duplicate-flags")
  local recipe="${dir}/recipe.yaml"
  "${EIDOS_BIN}" recipe --service eks --accelerator h100 --intent training -o "$recipe" >/dev/null 2>&1 || echo "kind: Recipe" > "$recipe"

  # All duplicate flag tests should fail with "can only be specified once"
  run_cmd_grep "dup/bundle-recipe" "can only be specified once" \
    "${EIDOS_BIN}" bundle --recipe "$recipe" --recipe "$recipe" -o "${dir}/out"

  run_cmd_grep "dup/validate-recipe" "can only be specified once" \
    "${EIDOS_BIN}" validate --recipe "$recipe" --recipe "$recipe" --snapshot "$recipe"

  run_cmd_grep "dup/recipe-service" "can only be specified once" \
    "${EIDOS_BIN}" recipe --service eks --service gke --accelerator h100 --intent training
}

# ============================================================================
# VALIDATE COMMAND AGENT FLAGS TEST
