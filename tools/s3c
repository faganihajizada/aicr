# s3c (Supply-Chain Check): Probes a component's container images for the
# presence of cosign signatures, SBOMs, and SLSA-style build provenance.
#
# This is a presence-only check. It does NOT verify that the artifacts were
# signed by the claimed publisher; that requires per-publisher trust roots
# (public keys or Sigstore certificate identities) which are out of scope.
#
# The list of images per component is read from the AICR container image
# inventory at docs/user/container-images.md (regenerated by `make bom-docs`).
#
# Usage:
#   tools/s3c <component-name> [-i <inventory-md>]
#   tools/s3c -h

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=tools/common
. "${DIR}/common"

INVENTORY="${REPO_ROOT}/docs/user/container-images.md"
COMPONENT=""

usage() {
  cat <<EOF
Usage: $(basename "$0") <component-name> [-i <inventory-md>]

Probes every image listed under the given component in the AICR container
image inventory for cosign signatures, SBOMs, and SLSA-style build
provenance. Presence-only — does NOT verify publisher identity.

Arguments:
  <component-name>            Component as it appears under "### <name>" in
                              the inventory (e.g., gpu-operator, nvsentinel).

Options:
  -i, --inventory PATH        Path to the inventory markdown
                              (default: docs/user/container-images.md)
  -h, --help                  Show this help.

Authentication:
  cosign authenticates via the Docker credential chain. To raise rate
  limits on nvcr.io / ghcr.io, run \`docker login\` once per registry
  before invoking this script. See:
    docs/user/container-images.md#authentication-and-rate-limits

Requires: cosign, jq, awk.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--inventory)
      [[ $# -ge 2 ]] || err "$1 requires an argument"
      INVENTORY="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      [[ $# -eq 1 ]] || err "expected exactly one component name after --"
      COMPONENT="$1"
      shift
      ;;
    -*)
      err "unknown flag: $1"
      ;;
    *)
      [[ -z "$COMPONENT" ]] || err "unexpected extra argument: $1"
      COMPONENT="$1"
      shift
      ;;
  esac
done

if [[ -z "$COMPONENT" ]]; then
  usage >&2
  exit 1
fi

[[ -f "$INVENTORY" ]] || err "inventory not found: $INVENTORY"

has_tools cosign jq awk

# Extract the per-component image list from the inventory markdown.
# The inventory format is:
#   ### <component>
#
#   - `<image-ref>`
#   - `<image-ref>`
#
# We capture every backtick-quoted bullet between the matching `### <name>`
# heading and the next `### ` heading.
images=$(awk -v c="$COMPONENT" '
  /^### / { in_section = ($2 == c); next }
  in_section && /^- `/ {
    line = $0
    sub(/^- `/, "", line)
    sub(/`$/, "", line)
    print line
  }
' "$INVENTORY")

if [[ -z "$images" ]]; then
  if grep -qE "^### ${COMPONENT}\$" "$INVENTORY"; then
    echo "Component: ${COMPONENT} (0 images, nothing to verify)"
    exit 0
  fi
  err "component '${COMPONENT}' not found in ${INVENTORY}"
fi

# probe_image emits a single tab-separated row:
#   <image>\t<sig>\t<sbom>\t<prov>\t<note>
# where each status is Y / - / ? (present / absent / unreachable).
probe_image() {
  local image="$1"
  local sig="-" sbom="-" prov="-" note=""

  # Single round-trip: cosign tree shows attached sigs/SBOMs/attestations.
  # Combine stdout+stderr so error patterns and section headings are both
  # available without needing a second file descriptor.
  local out rc=0
  out=$(cosign tree "$image" 2>&1) || rc=$?

  if [[ $rc -ne 0 ]]; then
    if echo "$out" | grep -qiE "MANIFEST_UNKNOWN|name unknown|not known|404"; then
      note="image not found"
    elif echo "$out" | grep -qiE "no such host|i/o timeout|connection refused|TLS handshake|x509"; then
      note="network unreachable"
    elif echo "$out" | grep -qiE "UNAUTHORIZED|denied|401|403"; then
      note="auth required"
    else
      note="probe failed"
    fi
    printf '%s\t?\t?\t?\t%s\n' "$image" "$note"
    return
  fi

  echo "$out" | grep -q "Signatures for an image tag:" && sig="Y"
  echo "$out" | grep -q "SBOMs for an image tag:" && sbom="Y"

  # Attestation presence alone is broader than SLSA; filter the predicateType
  # of each in-toto statement for slsa.dev / provenance. Capture stderr in a
  # separate file so the stdout JSON stays parseable by jq while still letting
  # us distinguish "no attestations attached" from a real probe failure.
  local att att_rc=0 att_err errfile
  errfile=$(mktemp 2>/dev/null || echo "${TMPDIR:-/tmp}/s3c-att.$$.err")
  att=$(cosign download attestation "$image" 2>"$errfile") || att_rc=$?
  att_err=$(cat "$errfile" 2>/dev/null || true)
  rm -f "$errfile"

  if [[ $att_rc -eq 0 && -n "$att" ]]; then
    if echo "$att" \
         | jq -r 'select(.payload != null) | .payload' 2>/dev/null \
         | while IFS= read -r b64; do
             [[ -z "$b64" ]] && continue
             echo "$b64" | base64 -d 2>/dev/null \
               | jq -r '.predicateType // empty' 2>/dev/null
           done \
         | grep -qiE "slsa|provenance"; then
      prov="Y"
    fi
  elif [[ $att_rc -ne 0 ]]; then
    # cosign exits non-zero both when no attestations exist (legitimate
    # absent) and when the registry call itself failed (unreachable).
    # Only the latter should flip prov to "?" so we don't mis-mark every
    # unattested image as unreachable. Treat unrecognized stderr as absent.
    if echo "$att_err" | grep -qiE "no such host|i/o timeout|connection refused|TLS handshake|x509|UNAUTHORIZED|denied|401|403"; then
      prov="?"
      [[ -z "$note" ]] && note="prov probe unreachable"
    fi
  fi

  printf '%s\t%s\t%s\t%s\t%s\n' "$image" "$sig" "$sbom" "$prov" "$note"
}

image_count=$(echo "$images" | wc -l | tr -d ' ')

# Compute the longest image string for column alignment.
maxlen=5  # header "Image"
while IFS= read -r img; do
  (( ${#img} > maxlen )) && maxlen=${#img}
done <<<"$images"

echo
echo "Component: ${COMPONENT} (${image_count} images)"
echo
echo "Presence-only check: does NOT verify publisher trust/identity."
echo "Y = artifact attached, - = artifact absent, ? = could not probe."
echo

# Header + divider sized to the widest column set.
printf "  %-${maxlen}s  %-3s  %-4s  %-4s  %s\n" "Image" "Sig" "SBOM" "Prov" "Notes"
printf "  %-${maxlen}s  %-3s  %-4s  %-4s  %s\n" \
  "$(printf -- '-%.0s' $(seq 1 "$maxlen"))" "---" "----" "----" "-----"

sig_yes=0
sbom_yes=0
prov_yes=0
unreachable=0

while IFS= read -r img; do
  IFS=$'\t' read -r ri rs rb rp rn <<<"$(probe_image "$img")"
  printf "  %-${maxlen}s  %-3s  %-4s  %-4s  %s\n" "$ri" "$rs" "$rb" "$rp" "$rn"
  [[ "$rs" == "Y" ]] && sig_yes=$((sig_yes + 1))
  [[ "$rb" == "Y" ]] && sbom_yes=$((sbom_yes + 1))
  [[ "$rp" == "Y" ]] && prov_yes=$((prov_yes + 1))
  [[ "$rs" == "?" ]] && unreachable=$((unreachable + 1))
done <<<"$images"

echo
printf "Summary: %d/%d signed · %d/%d SBOM · %d/%d provenance" \
  "$sig_yes" "$image_count" "$sbom_yes" "$image_count" "$prov_yes" "$image_count"
if [[ $unreachable -gt 0 ]]; then
  printf " · %d unreachable" "$unreachable"
fi
echo
echo
